  "components": {
    "schemas": {
      "ColorRequest": {
        "properties": {
          "r": {
            "type": "integer",
            "maximum": 255.0,
            "minimum": 0.0,
            "title": "R",
            "default": 0
          },
          "g": {
            "type": "integer",
            "maximum": 255.0,
            "minimum": 0.0,
            "title": "G",
            "default": 0
          },
          "b": {
            "type": "integer",
            "maximum": 255.0,
            "minimum": 0.0,
            "title": "B",
            "default": 0
          },
          "brightness": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Brightness",
            "default": 1.0
          },
          "transition_ms": {
            "type": "integer",
            "maximum": 60000.0,
            "minimum": 0.0,
            "title": "Transition Ms",
            "default": 500
          }
        },
        "type": "object",
        "title": "ColorRequest"
      },
      "EffectRequest": {
        "properties": {
          "speed": {
            "anyOf": [{ "type": "number" }, { "type": "null" }],
            "title": "Speed"
          },
          "r": {
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "title": "R"
          },
          "g": {
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "title": "G"
          },
          "b": {
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "title": "B"
          },
          "brightness": {
            "anyOf": [{ "type": "number" }, { "type": "null" }],
            "title": "Brightness"
          },
          "period_ms": {
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "title": "Period Ms"
          },
          "step_ms": {
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "title": "Step Ms"
          }
        },
        "type": "object",
        "title": "EffectRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": { "$ref": "#/components/schemas/ValidationError" },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": { "anyOf": [{ "type": "string" }, { "type": "integer" }] },
            "type": "array",
            "title": "Location"
          },
          "msg": { "type": "string", "title": "Message" },
          "type": { "type": "string", "title": "Error Type" },
          "input": { "title": "Input" },
          "ctx": { "type": "object", "title": "Context" }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    }
  }
